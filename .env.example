# Copy this file to .env and fill in real values.
# Do not commit real secrets.

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# Chat/extraction model, OpenAI-compatible endpoint.
# DeepSeek V4 official OpenAI-compatible base URL: https://api.deepseek.com
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_API_KEY=change_me
DEEPSEEK_API_KEY=change_me
MODEL_NAME=deepseek-v4-pro
EXTRACT_MODEL=deepseek-v4-pro
CHAT_API_BASE=https://api.deepseek.com

# Optional embedding provider.
# DeepSeek V4 is used for chat/extraction; embeddings still need a separate provider.
EMBEDDING_API_KEY=change_me
SILICONFLOW_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1/embeddings

# Runtime
LOG_LEVEL=INFO
KG_VERSION=v0.1
EMBEDDING_VERSION=bge-m3-v0.1
OFFLINE_GRAPH_FALLBACK=true
